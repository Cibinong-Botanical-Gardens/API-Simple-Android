<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="15dp"
    android:layout_marginEnd="15dp"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Gambar Artikel -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="180dp">

            <ImageView
                android:id="@+id/img_artikel"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="@android:color/darker_gray"/>

            <ImageView
                android:id="@+id/img_logo_placeholder"
                android:layout_width="90dp"
                android:layout_height="30dp"
                android:layout_gravity="center"
                android:alpha="0.4"
                android:src="@drawable/ic_logo_tumbang"/>

            <!-- Gradient overlay di bawah gambar -->
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:alpha="0.4"
                android:src="@drawable/shape_shadow"/>

        </FrameLayout>

        <!-- Konten Artikel -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <!-- Judul -->
            <TextView
                android:id="@+id/tv_judul_artikel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginBottom="6dp"
                tools:text="Judul Artikel Panjang Sekali"/>

            <!-- Deskripsi -->
            <TextView
                android:id="@+id/tv_deskripsi_artikel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:maxLines="3"
                android:ellipsize="end"
                android:alpha="0.7"
                android:layout_marginBottom="10dp"
                tools:text="Deskripsi artikel yang cukup panjang dan bisa beberapa baris"/>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="?android:attr/listDivider"
                android:layout_marginBottom="10dp"/>

            <!-- Footer: user + tanggal -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Avatar placeholder -->
                <androidx.cardview.widget.CardView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    app:cardCornerRadius="50dp"
                    app:cardElevation="0dp">

                    <ImageView
                        android:id="@+id/img_avatar_artikel"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/img_avatar"
                        android:scaleType="centerCrop"/>

                </androidx.cardview.widget.CardView>

                <Space
                    android:layout_width="8dp"
                    android:layout_height="match_parent"/>

                <!-- Nama user -->
                <TextView
                    android:id="@+id/tv_nama_user_artikel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:singleLine="true"
                    android:ellipsize="end"
                    tools:text="Nama Penulis"/>

                <!-- Tanggal publish -->
                <TextView
                    android:id="@+id/tv_tanggal_artikel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:alpha="0.6"
                    tools:text="23 Jul 2026"/>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
