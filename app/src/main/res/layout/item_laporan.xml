<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="15dp"
    android:layout_marginEnd="15dp"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Header: Badge prioritas + Jenis laporan -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tv_jenis_laporan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/shape_myplants"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="?colorPrimary"
                tools:text="Kerusakan Pohon"/>

            <Space android:layout_width="8dp" android:layout_height="match_parent"/>

            <TextView
                android:id="@+id/tv_prioritas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:alpha="0.6"
                tools:text="Prioritas: Tinggi"/>

            <Space android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"/>

            <TextView
                android:id="@+id/tv_status_laporan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textStyle="bold"
                tools:text="Pending"/>

        </LinearLayout>

        <!-- Judul Laporan -->
        <TextView
            android:id="@+id/tv_judul_laporan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginBottom="6dp"
            tools:text="Judul Laporan"/>

        <!-- Deskripsi -->
        <TextView
            android:id="@+id/tv_deskripsi_laporan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:alpha="0.7"
            android:layout_marginBottom="10dp"
            tools:text="Deskripsi laporan"/>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="?android:attr/listDivider"
            android:layout_marginBottom="10dp"/>

        <!-- Footer: user + tanggal -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Avatar placeholder -->
            <androidx.cardview.widget.CardView
                android:layout_width="30dp"
                android:layout_height="30dp"
                app:cardCornerRadius="50dp"
                app:cardElevation="0dp">

                <ImageView
                    android:id="@+id/img_avatar_laporan"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/img_avatar"
                    android:scaleType="centerCrop"/>

            </androidx.cardview.widget.CardView>

            <Space android:layout_width="8dp" android:layout_height="match_parent"/>

            <!-- Nama pelapor -->
            <TextView
                android:id="@+id/tv_nama_user_laporan"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="12sp"
                android:textStyle="bold"
                android:singleLine="true"
                android:ellipsize="end"
                tools:text="Nama Pelapor"/>

            <!-- Tanggal -->
            <TextView
                android:id="@+id/tv_tanggal_laporan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:alpha="0.6"
                tools:text="23 Jul 2026"/>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
