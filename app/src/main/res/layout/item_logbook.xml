<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="15dp"
    android:layout_marginEnd="15dp"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- Icon kegiatan kiri -->
        <androidx.cardview.widget.CardView
            android:layout_width="44dp"
            android:layout_height="44dp"
            app:cardCornerRadius="10dp"
            app:cardBackgroundColor="?colorPrimary"
            app:cardElevation="0dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_round_check_24"
                app:tint="@color/white"/>

        </androidx.cardview.widget.CardView>

        <Space android:layout_width="12dp" android:layout_height="match_parent"/>

        <!-- Konten teks tengah -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Jenis kegiatan / judul -->
            <TextView
                android:id="@+id/tv_jenis_kegiatan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textStyle="bold"
                android:singleLine="true"
                android:ellipsize="end"
                tools:text="Pemangkasan Pohon"/>

            <!-- Area -->
            <TextView
                android:id="@+id/tv_area"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:alpha="0.7"
                android:singleLine="true"
                android:ellipsize="end"
                android:layout_marginTop="2dp"
                tools:text="Area A — Blok 3"/>

            <!-- ID Pohon -->
            <TextView
                android:id="@+id/tv_id_tree"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:alpha="0.5"
                android:layout_marginTop="2dp"
                tools:text="ID: TR-001"/>

        </LinearLayout>

        <Space android:layout_width="8dp" android:layout_height="match_parent"/>

        <!-- Tanggal kanan -->
        <TextView
            android:id="@+id/tv_tanggal_logbook"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:alpha="0.6"
            android:gravity="end"
            tools:text="23 Jul 2026"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>
